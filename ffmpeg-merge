#!/bin/bash
# USAGE: ./merge_audio.sh <low_quality_video_with_good_audio> <high_quality_video_with_bad_audio>

# Check if exactly two arguments are provided
if [ "$#" -ne 2 ]; then
    echo "Usage: $0 <low_quality_audio_source> <high_quality_video_source>"
    echo ""
    echo "Example:"
    echo "$0 low_res_v1.mp4 high_res_v2.mp4"
    exit 1
fi

LOW_AUDIO_SOURCE="$1"
HIGH_VIDEO_SOURCE="$2"

# Derive an output filename from the high-quality video source
# This strips the extension and adds '_merged.mkv'
OUTPUT_NAME="${HIGH_VIDEO_SOURCE%.*}-merged.mkv"

echo "--------------------------------------------------------"
echo "Merging Tracks..."
echo "  Audio Source: $LOW_AUDIO_SOURCE (Input 0)"
echo "  Video Source: $HIGH_VIDEO_SOURCE (Input 1)"
echo "  Output File:  $OUTPUT_NAME"
echo "--------------------------------------------------------"

ffmpeg -i "$LOW_AUDIO_SOURCE" \
       -i "$HIGH_VIDEO_SOURCE" \
       -map 1 \
       -map 0:a \
       -c copy \
       "$OUTPUT_NAME"


# Check the exit status of FFmpeg
if [ $? -eq 0 ]; then
    echo "--------------------------------------------------------"
    echo "Success! The merged video is saved as: $OUTPUT_NAME"
else
    echo "--------------------------------------------------------"
    echo "Error: FFmpeg failed to merge the streams."
    echo "Please check the input file paths and ensure FFmpeg is installed."
fi

