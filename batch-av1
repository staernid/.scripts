#!/bin/bash

# Default values
CRF=38
PRESET=4
ANIME_MODE=false
FILES=()

# Display help message
show_help() {
    echo "Usage: $(basename "$0") [OPTIONS] [FILES...]"
    echo ""
    echo "Batch convert video files to AV1 using SVT-AV1."
    echo ""
    echo "Options:"
    echo "  -a, --anime         Enable anime mode (adds film-grain=4)"
    echo "  -c, --crf VALUE     Set CRF value (default: $CRF)"
    echo "  -p, --preset VALUE  Set SVT-AV1 preset (default: $PRESET)"
    echo "  -h, --help          Show this help message"
    echo ""
    echo "If no files are provided, all .mp4 files in the current directory will be processed."
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        -a|--anime)
            ANIME_MODE=true
            shift
            ;;
        -c|--crf)
            CRF="$2"
            shift 2
            ;;
        -p|--preset)
            PRESET="$2"
            shift 2
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        -*)
            echo "Unknown option: $1"
            show_help
            exit 1
            ;;
        *)
            FILES+=("$1")
            shift
            ;;
    esac
done

# If no files provided, default to *.mp4
if [ ${#FILES[@]} -eq 0 ]; then
    shopt -s nullglob
    FILES=(*.mp4)
fi

if [ ${#FILES[@]} -eq 0 ]; then
    echo "Error: No files to process."
    exit 1
fi

# Construct SVT-AV1 parameters
SVTAV1_PARAMS="tune=2:sharpness=1:qm-min=2:chroma-qm-max=15:qp-scale-compress-strength=2:enable-variance-boost=1:variance-boost-strength=1:variance-octile=4"
if [ "$ANIME_MODE" = true ]; then
    SVTAV1_PARAMS="$SVTAV1_PARAMS:film-grain=4"
    echo "--- Anime mode enabled ---"
fi

FFMPEG_OPTIONS=(
    -c:v libsvtav1
    -crf "$CRF"
    -preset "$PRESET"
    -pix_fmt yuv420p10le
    -svtav1-params "$SVTAV1_PARAMS"
    -c:a copy
)

echo "--- Starting AV1 Batch Conversion ---"
echo "--- CRF: $CRF, Preset: $PRESET"

for INPUT_FILE in "${FILES[@]}"; do
    if [[ ! -f "$INPUT_FILE" ]]; then
        echo "--- Skipping: $INPUT_FILE (Not a file)"
        continue
    fi

    # Determine output filename
    filename=$(basename -- "$INPUT_FILE")
    extension="${filename##*.}"
    filename="${filename%.*}"
    OUTPUT_FILE="${filename}_AV1.mkv"

    echo "--- Processing: $INPUT_FILE"
    echo "--- Output: $OUTPUT_FILE"

    ffmpeg -i "$INPUT_FILE" "${FFMPEG_OPTIONS[@]}" "$OUTPUT_FILE"

    if [ $? -eq 0 ]; then
        echo "--- Finished: $INPUT_FILE (Success)"
    else
        echo "--- Error: $INPUT_FILE (FFmpeg failed)"
        echo "$(date): Error processing $INPUT_FILE" >> ./ffmpeg-error-log.txt
    fi
    echo "-------------------------------------"
done

echo "--- Batch processing complete! ---"
